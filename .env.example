# === Local Development ===
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://pcndev:devpassword@localhost:5432/pcn_eol_db

# Azure OpenAI (set AI_SERVICE_MODE=mock to skip)
AI_SERVICE_MODE=mock
AZURE_OPENAI_ENDPOINT=https://your-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Denodo
DENODO_REST_BASE_URL=https://dataplatform.advantech.com.tw:9443/server/dx_ce
DENODO_USERNAME=your-username
DENODO_PASSWORD=your-password

# Email Ingestion
EMAIL_INGEST_MODE=mock

# Local uploads
LOCAL_UPLOAD_DIR=./uploads

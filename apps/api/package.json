{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/app.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixtures": "tsx scripts/test-runner.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@kenjiuno/msgreader": "^1.28.0",
    "@prisma/client": "^6.4.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.0",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.5",
    "openai": "^4.85.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "shared": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/adm-zip": "^0.5.8",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.13.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.4",
    "eslint": "^9.20.0",
    "prisma": "^6.4.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.0.0"
  }
}
